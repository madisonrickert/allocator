# ───────────────────────────────────────────────
# Security: never commit user data or credentials
# ───────────────────────────────────────────────
.env
.env.*
*.key
*.pem
secrets.*
.credentials/
*credentials*.json
*.token

# Local fixtures with real data (only synthetic fixtures may be committed)
tests/fixtures/real_*
tests/fixtures/private_*
fixtures/real_*

# Generated snapshots / caches (should live in ~/.cache, not the repo, but be safe)
snapshot.json
snapshots/
.cache/

# uv
uv.lock.user
